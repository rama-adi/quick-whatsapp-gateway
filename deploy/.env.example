# Copy to .env at the repo root and fill in. The server loads .env on boot in
# dev (no-op if absent; prod injects real env). See masterplan §12 + §20.

# --- HTTP / server ---
HTTP_ADDR=:8080
PUBLIC_URL=http://localhost:8080

# --- Secrets ---
APP_ENCRYPTION_KEY=        # openssl rand -base64 32

# --- App data store (MySQL) ---
MYSQL_DSN=gw:gwpass@tcp(127.0.0.1:3306)/gateway?parseTime=true&charset=utf8mb4

# --- whatsmeow keystore ---
# Driver: mysql | sqlite. Dev default below uses MySQL; for the zero-config
# fallback set WHATSMEOW_STORE_DRIVER=sqlite and a file: DSN.
WHATSMEOW_STORE_DRIVER=mysql
WHATSMEOW_STORE_DSN=gw:gwpass@tcp(127.0.0.1:3306)/gateway?parseTime=true&charset=utf8mb4
# WHATSMEOW_STORE_DRIVER=sqlite
# WHATSMEOW_STORE_DSN=file:store.db?_foreign_keys=on

# --- Infra ---
REDIS_URL=redis://127.0.0.1:6379

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Admin WhatsApp number ---
WHATSAPP_ADMIN_NUMBER=628xxxxxxxx
WHATSAPP_ADMIN_CMD_PREFIX=am

# --- Panels ---
USER_PANEL_ENABLED=true

# --- Per-session defaults ---
DEFAULT_RATE_PER_MIN=20
DEFAULT_RATE_PER_HOUR=200
DEFAULT_AUTO_READ=true

# --- Source-level ignore rules ---
IGNORE_STATUS=false
IGNORE_GROUPS=false
IGNORE_CHANNELS=false
IGNORE_BROADCAST=false

# --- Global webhook defaults ---
WEBHOOK_URL=
WEBHOOK_EVENTS=
WEBHOOK_HMAC_KEY=
WEBHOOK_RETRIES_DELAY=2
WEBHOOK_RETRIES_ATTEMPTS=15

# --- Data retention ---
RETENTION_DAYS=0

# --- Observability ---
LOG_LEVEL=debug
