# GATEWAY (Go / whatsmeow) configuration — masterplan §14.
# Copy to .env at the repo root and fill in. The server loads .env on boot in
# dev (no-op if absent; prod injects real env). Frontend vars live separately
# in web/.env.example.

# --- HTTP / server ---
HTTP_ADDR=:8080
# This gateway's id (rows in `gateways`, `wa_sessions.gateway_id`).
GATEWAY_ID=gw-1
# External base URL of this gateway.
PUBLIC_URL=http://localhost:8080

# --- Trust seam (better-auth) ---
# The frontend's base URL = the JWT iss/aud this gateway enforces. No trailing slash.
BETTER_AUTH_URL=http://localhost:3000
# JWKS endpoint to fetch/cache. Defaults to ${BETTER_AUTH_URL}/api/auth/jwks if unset.
# BETTER_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
# Comma-list of browser origins allowed to call the gateway (CORS).
FRONTEND_ORIGINS=http://localhost:3000

# --- Secrets ---
APP_ENCRYPTION_KEY=        # base64 32-byte AES-GCM key: openssl rand -base64 32

# --- App data store (shared MySQL: WA tables rw; apikey/user ro) ---
MYSQL_DSN=gw:gwpass@tcp(127.0.0.1:3306)/gateway?parseTime=true&charset=utf8mb4

# --- whatsmeow keystore (pure-Go SQLite, persistent) ---
# In containers this lives on the /data/keystore volume. For host-run dev a
# relative file is fine; switch to the /data path when running in Docker.
WHATSMEOW_STORE_DSN=file:store.db?_pragma=foreign_keys(on)&_pragma=journal_mode(WAL)
# WHATSMEOW_STORE_DSN=file:/data/keystore/store.db?_pragma=foreign_keys(on)&_pragma=journal_mode(WAL)

# --- Redis ---
# Work bus: asynq queue, rate-limit, idempotency, stream fan-out, cache.
REDIS_URL=redis://127.0.0.1:6379
# Control bus for cross-service ctrl:* pub/sub (key/user revocation). Defaults
# to REDIS_URL in single-instance deployments.
# PUBSUB_REDIS_URL=redis://127.0.0.1:6379
# Key/channel namespace so multiple stacks can share one Redis.
REDIS_PREFIX=gw

# --- Admin WhatsApp number ---
# Admin number provisioned/paired on boot.
WHATSAPP_ADMIN_NUMBER=628xxxxxxxx
# Optional: better-auth user id that owns the admin session.
# GATEWAY_ADMIN_USER_ID=
# Private command prefix on the admin session.
WHATSAPP_ADMIN_CMD_PREFIX=am

# --- Per-session defaults ---
DEFAULT_RATE_PER_MIN=20
DEFAULT_RATE_PER_HOUR=200
DEFAULT_AUTO_READ=true

# --- Source-level ignore rules ---
IGNORE_STATUS=false
IGNORE_GROUPS=false
IGNORE_CHANNELS=false
IGNORE_BROADCAST=false

# --- Global webhook defaults ---
WEBHOOK_URL=
WEBHOOK_EVENTS=
WEBHOOK_HMAC_KEY=
WEBHOOK_RETRIES_DELAY=2
WEBHOOK_RETRIES_ATTEMPTS=15

# --- Data retention ---
RETENTION_DAYS=0

# --- Observability ---
LOG_LEVEL=info
