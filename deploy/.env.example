# ROUTER + GATEWAY (Go / whatsmeow) configuration — masterplan §14.
# Copy to deploy/.env and fill in. This one file is the env for BOTH the host
# (`make dev` loads deploy/.env) and the Docker dev profiles (`--profile
# router|gateway[-dev]` read it via env_file; the compose overrides only the
# in-container service hostnames + keystore path). In prod the values are real
# env vars injected by your platform. `deploy/docker-compose.selfhost.yml` also
# reads the frontend essentials from this file for a single-box install. Full
# frontend vars live separately in web/.env.example.
#
# Topology: the ROUTER is the single public front door + trust boundary.
# Browsers/clients talk to the ROUTER, which authenticates the caller
# (better-auth JWT or api-key), resolves the owning gateway, and reverse-proxies
# with a request-bound internal assertion. The GATEWAY is now INTERNAL — it no
# longer authenticates end users; it only verifies the router's assertion.

# --- Central router ---
# Address the router listens on.
ROUTER_HTTP_ADDR=:8090
# External base URL of the router (this is the URL browsers/clients use).
ROUTER_PUBLIC_URL=http://localhost:8090
# Issuer (iss) the router stamps on its internal assertions; the gateway's
# ROUTER_ASSERTION_ISSUER must match. Default "router".
ROUTER_ISSUER=router
# Ed25519 private key for minting internal assertions. REQUIRED. Base64 of a
# 32-byte seed or a full Ed25519 key, e.g. generate with: openssl rand 32 | base64
ROUTER_ED25519_PRIVATE_KEY=

# --- HTTP / server ---
HTTP_ADDR=:8080
# This gateway's id (rows in `gateways`, `wa_sessions.gateway_id`). Also the
# audience (aud) the gateway requires on the router's assertions.
GATEWAY_ID=gw-1
# Internal base URL of this gateway — the base_url the ROUTER proxies to. Must be
# reachable from the router (not the browser; clients hit ROUTER_PUBLIC_URL).
PUBLIC_URL=http://localhost:8080

# --- Trust seam (better-auth) — now primarily the ROUTER's authn inputs ---
# The frontend's base URL = the JWT iss/aud the ROUTER enforces. No trailing slash.
BETTER_AUTH_URL=http://localhost:3000
# JWKS endpoint to fetch/cache. Defaults to ${BETTER_AUTH_URL}/api/auth/jwks if unset.
# BETTER_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
# Comma-list of browser origins allowed to call the ROUTER (CORS lives on the
# router now; the gateway no longer mounts CORS).
FRONTEND_ORIGINS=http://localhost:3000

# --- Router->gateway assertion seam (gateway side) ---
# The router's JWKS for verifying internal assertions. REQUIRED for the gateway.
ROUTER_JWKS_URL=http://localhost:8090/.well-known/router-jwks.json
# Issuer (iss) the gateway requires on the router's assertions; must match the
# router's ROUTER_ISSUER. Default "router".
ROUTER_ASSERTION_ISSUER=router

# --- Secrets ---
APP_ENCRYPTION_KEY=        # base64 32-byte AES-GCM key: openssl rand -base64 32
# Required by the frontend in the self-host compose file: openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- App data store (shared MySQL: WA tables rw; apikey/user ro) ---
MYSQL_DSN=gw:gwpass@tcp(127.0.0.1:3306)/gateway?parseTime=true&charset=utf8mb4&clientFoundRows=true

# --- whatsmeow keystore (pure-Go SQLite, persistent) ---
# In containers this lives on the /data/keystore volume. For host-run dev a
# relative file is fine; switch to the /data path when running in Docker.
WHATSMEOW_STORE_DSN=file:store.db?_pragma=foreign_keys(on)&_pragma=journal_mode(WAL)
# WHATSMEOW_STORE_DSN=file:/data/keystore/store.db?_pragma=foreign_keys(on)&_pragma=journal_mode(WAL)

# --- Redis ---
# Work bus: asynq queue, rate-limit, idempotency, stream fan-out, cache.
REDIS_URL=redis://127.0.0.1:6379
# Control bus for cross-service ctrl:* pub/sub (key/user revocation). The router
# subscribes to it (evicting its api-key cache); the frontend publishes to it.
# Defaults to REDIS_URL in single-instance deployments.
# PUBSUB_REDIS_URL=redis://127.0.0.1:6379
# Key/channel namespace so multiple stacks can share one Redis.
REDIS_PREFIX=gw

# --- Admin WhatsApp number ---
# Admin number provisioned/paired on boot. Digits only, no '+' (e.g. 628123456789).
WHATSAPP_ADMIN_NUMBER=628xxxxxxxx
# Required when WHATSAPP_ADMIN_NUMBER is set: the organization that owns the admin
# session. Must be a real id from better-auth's `organization` table — find it with
#   SELECT id, name FROM organization;
# (the first signup's personal org is a good choice for a single-tenant deploy).
WHATSAPP_ADMIN_ORG_ID=
# Optional: better-auth user id that owns the admin session.
# GATEWAY_ADMIN_USER_ID=
# Private command prefix on the admin session.
WHATSAPP_ADMIN_CMD_PREFIX=am
# Optional OS/app label for newly paired gateway sessions. Leave empty to show
# "Chrome (Linux - <GATEWAY_ID>)" in WhatsApp's Linked devices list.
WHATSAPP_DEVICE_NAME=

# --- Per-session defaults ---
DEFAULT_RATE_PER_MIN=20
DEFAULT_RATE_PER_HOUR=200
DEFAULT_AUTO_READ=true

# --- Source-level ignore rules ---
IGNORE_STATUS=false
IGNORE_GROUPS=false
IGNORE_CHANNELS=false
IGNORE_BROADCAST=false

# --- Global webhook defaults ---
WEBHOOK_URL=
WEBHOOK_EVENTS=
WEBHOOK_HMAC_KEY=
WEBHOOK_RETRIES_DELAY=2
WEBHOOK_RETRIES_ATTEMPTS=15

# --- Data retention ---
RETENTION_DAYS=0

# --- Observability ---
LOG_LEVEL=info

# --- Frontend note (web/.env.example) ---
# The browser-facing API base URL (VITE_GATEWAY_URL in web/.env.example) must
# point at the ROUTER (port 8090 / ROUTER_PUBLIC_URL), NOT the gateway (8080).
# The router is the single public front door.
# Self-host default is locked down: USER_REGISTRATION_ENABLED=false unless you
# explicitly set it true in deploy/.env.
USER_REGISTRATION_ENABLED=false
# Optional: comma-separated better-auth user ids granted platform super-admin.
ADMIN_USER_IDS=
