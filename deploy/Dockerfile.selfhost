# syntax=docker/dockerfile:1
# SELF-HOST app image: router + gateway + frontend in one container.
#
# This is for simple single-box installs. MySQL, Redis, and the WhatsApp
# keystore remain outside the image on Compose services/volumes.

# --- Stage 1: build Go binaries ---
FROM golang:1.26-alpine AS go-build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/router ./cmd/router
RUN CGO_ENABLED=0 go build -o /out/gateway ./cmd/server

# --- Stage 2: build frontend ---
FROM node:22-alpine AS web-build
WORKDIR /web
RUN corepack enable
COPY web/package.json web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY web/ ./
ENV NITRO_PRESET=node-server SERVER_PRESET=node-server
RUN pnpm build

# --- Stage 3: runtime ---
FROM node:22-alpine
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app

COPY --from=go-build /out/router /usr/local/bin/router
COPY --from=go-build /out/gateway /usr/local/bin/gateway
COPY --from=web-build /web/.output /web/.output
COPY docs/openapi.yaml /docs/openapi.yaml
COPY deploy/selfhost-entrypoint.sh /usr/local/bin/selfhost-entrypoint
RUN chmod +x /usr/local/bin/selfhost-entrypoint

VOLUME ["/data/keystore"]
EXPOSE 3000 8090
ENTRYPOINT ["selfhost-entrypoint"]
