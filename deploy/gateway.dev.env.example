# Extra/override gateway env for the Dockerized dev gateway (compose profiles
# "gateway" and "gateway-dev"). Copy to gateway.dev.env (gitignored) and add the
# vars you need, one KEY=value per line.
#
# Vars set in the service's `environment:` block in docker-compose.dev.yml win
# over this file — to change those (MYSQL_DSN, REDIS_URL, BETTER_AUTH_URL, …),
# edit the compose block. Use this file for vars NOT already set there, e.g.:

# WHATSAPP_ADMIN_NUMBER=628xxxxxxxx
# GATEWAY_ADMIN_USER_ID=
# IGNORE_GROUPS=true
# IGNORE_STATUS=true
# DEFAULT_RATE_PER_MIN=20
# DEFAULT_RATE_PER_HOUR=200
# WEBHOOK_URL=
# RETENTION_DAYS=0
