# Dev-only gateway image: full Go toolchain + air for hot reload INSIDE Docker.
# Used by the docker-compose.dev.yml "gateway-dev" profile, which mounts the
# repo at /src so edits on the host trigger an in-container rebuild via air
# (see .air.toml). This keeps the dev gateway on the same OS/toolchain as prod
# while keeping the fast edit→reload loop.
#
# NOT for production — prod uses deploy/Dockerfile, which ships a tiny static
# CGO-free binary with no toolchain.
FROM golang:1.26-alpine
RUN apk add --no-cache git ca-certificates tzdata \
 && go install github.com/air-verse/air@latest
WORKDIR /src
ENV CGO_ENABLED=0
EXPOSE 8080
CMD ["air"]
