# syntax=docker/dockerfile:1
# FRONTEND image (TanStack Start + better-auth, Node). Build context is the
# repo root so the web/ paths below resolve:
#   docker build -t whatsmeow-gateway-web -f deploy/Dockerfile.web .

# --- Stage 1: install deps + build the TanStack Start server bundle ---
FROM node:22-alpine AS build
WORKDIR /web
RUN corepack enable
COPY web/package.json web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY web/ ./
# Force the node-server preset. Nitro auto-detects the build host and would emit
# the `zeabur` preset (.zeabur/output) when built on Zeabur, but this image
# serves the standalone node output (.output/server/index.mjs).
ENV NITRO_PRESET=node-server SERVER_PRESET=node-server
RUN pnpm build                       # nitro node-server preset -> /web/.output

# --- Stage 2: runtime (Node server) ---
# The build self-contains its runtime deps under .output, so no second
# `pnpm install` is needed — copy the standalone server output and run it.
FROM node:22-alpine
WORKDIR /web
ENV NODE_ENV=production
COPY --from=build /web/.output ./.output
EXPOSE 3000
CMD ["node", ".output/server/index.mjs"]
