# Frontend (TanStack Start + better-auth) configuration — masterplan §14.
# Copy to .env and fill in. Do NOT commit .env (only this .example).

# --- better-auth ---
# Signing/encryption secret (min 32 chars). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32+-char-random-secret
# The frontend's own base URL. Used as the JWT issuer/audience (iss==aud) the
# gateway enforces, and the JWKS/token origin. No trailing slash.
BETTER_AUTH_URL=http://localhost:3000
# Optional: comma-list of extra trusted origins for CSRF/origin checks.
# TRUSTED_ORIGINS=https://app.example.com
# Optional: comma-list of better-auth user ids bootstrapped as platform super_admin.
# ADMIN_USER_IDS=

# --- Database (Drizzle / MySQL) ---
# MySQL DSN for the frontend's Drizzle client: better-auth tables (single-writer)
# + read-only WA-data queries. Use a pooler in serverless (§12).
DATABASE_URL=mysql://user:password@localhost:3306/wa_gateway

# --- API base URL (the ROUTER, the single public front door) ---
# Base URL the frontend server references for actions (no trailing slash). This
# is the ROUTER (port 8090), NOT the gateway — the router authenticates the
# caller and proxies to the owning gateway.
GATEWAY_URL=http://localhost:8090
# Same value exposed to the BROWSER (Vite inlines VITE_ vars). The browser calls
# the ROUTER directly with a Bearer JWT for both REST actions and the realtime
# WebSocket.
VITE_GATEWAY_URL=http://localhost:8090

# --- Control bus (publish-only) ---
# Redis the frontend PUBLISHES ctrl:* revocations to (= the gateways'
# PUBSUB_REDIS_URL). In single-instance dev this is the gateway's REDIS_URL.
# If unset, revocation publishing is a no-op (gateways fall back to their ~60s
# api-key cache TTL backstop). The frontend NEVER touches the work Redis.
PUBSUB_REDIS_URL=redis://localhost:6379

# --- Feature gates ---
# Gate self-registration (sign-up). Set to "false" to lock it down. Default: enabled.
USER_REGISTRATION_ENABLED=true
# Show the developer ("Contributing") docs under /docs/dev. Set to "false" in
# prod to hide that section from the docs nav and 404 its pages. Default: shown.
SHOW_CONTRIB_WIKI=true
